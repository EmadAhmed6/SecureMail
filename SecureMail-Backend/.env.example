# ─── App ──────────────────────────────────────────────────────────
NODE_ENV=production
APP_PORT=3000

# ─── PostgreSQL ───────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:0000@localhost:5432/securemail?schema=public"
DB_USER=postgres
DB_PASSWORD=StrongPassword123!
DB_NAME=securemail
DB_PORT=5432

# ─── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-very-long-random-secret
JWT_EXPIRES_IN=7d

# ─── Mailer (SMTP) ────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# ─── Redis ────────────────────────────────────────────────────────
# If running with docker-compose, REDIS_HOST should be 'redis'
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Encryption ───────────────────────────────────────────────────
# Must be at least 32 characters for AES-256
ENCRYPTION_KEY=your-secure-encryption-key-at-least-32-chars!!

# ─── Google OAuth2 ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ─── Microsoft OAuth2 ─────────────────────────────────────────────
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_TENANT_ID=common

# ─── Frontend ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001

# ─── Cloudinary ───────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Threat Intelligence ──────────────────────────────────────────
ABUSEIPDB_API_KEY=your-abuseipdb-key

# ─── Mailbox ──────────────────────────────────────────────────────
# 1GB default; LOW_MAILBOX_SPACE triggers at 80%
MAILBOX_STORAGE_LIMIT_BYTES=1073741824

# ─── Admin Seed ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@securemail.local
ADMIN_PASSWORD=Admin123!

# ─── External / Public URLs ───────────────────────────────────────
PUBLIC_API_URL=http://localhost:3000

# ─── Microservices (gRPC) ─────────────────────────────────────────
# Uncomment and configure these if you are running the AI or Malware services locally or via Docker
# AI_AGENT_GRPC_URL=localhost:50051
# MALWARE_GRPC_URL=localhost:50052