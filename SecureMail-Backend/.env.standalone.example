# ─────────────────────────────────────────────────────────────────────────────
# SecureMail-Backend — STANDALONE mode
# Use: cd SecureMail-Backend && ./setup.sh  (Mac/Linux)
#              OR               setup.bat   (Windows)
#
# AI and Malware gRPC services are NOT started in standalone mode.
# The backend handles their unavailability gracefully (no crash).
# Both AiAgentService and MalwareService return { ok: false } when
# the gRPC connection fails — the security pipeline continues without them.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# POSTGRES_PASSWORD is the single source of truth — docker-compose reads it too
POSTGRES_PASSWORD=YOUR_DB_PASSWORD
DATABASE_URL="postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/securemail?schema=public"

# ── gRPC ──────────────────────────────────────────────────────────────────────
# localhost because AI/Malware are NOT running in standalone mode
# Graceful degradation: connection fails → pipeline skips those stages
AI_AGENT_GRPC_URL=localhost:50051
MALWARE_GRPC_URL=localhost:50052

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your-very-long-random-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d

# ── Mail (SMTP) ───────────────────────────────────────────────────────────────
MAIL_HOST="smtp.gmail.com"
SMTP_USERNAME="your-email@gmail.com"
SMTP_PASSWORD="your-gmail-app-password"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Encryption ────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=your-secure-encryption-key-at-least-32-characters

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ── Microsoft OAuth2 ──────────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_TENANT_ID=common

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001

# ── Mailbox ───────────────────────────────────────────────────────────────────
MAILBOX_STORAGE_LIMIT_BYTES=1073741824

# ── Admin Seed ────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@securemail.local
ADMIN_PASSWORD=Admin123!

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# ── Threat Intelligence ───────────────────────────────────────────────────────
ABUSEIPDB_API_KEY=your-abuseipdb-api-key